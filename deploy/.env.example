# ─────────────────────────────────────────────────────────────
# Lot Agent — docker-compose environment.
# Copy this file to the repo-root `.env` (NOT committed) and fill it in:
#     cp deploy/.env.example .env
# docker-compose reads `.env` automatically for ${VAR} interpolation.
#
# Host wiring (PG_HOST=postgres, REDIS_HOST=redis, REDIS_URL, PORT, ...) is set
# inside docker-compose.yml — you only provide secrets and a few choices here.
# ─────────────────────────────────────────────────────────────

# ---- PostgreSQL (REQUIRED) ----
PG_USER=postgres
PG_PASSWORD=change-me-strong-pg-password
PG_DATABASE=lot

# ---- Redis (REQUIRED) ----
# Used to build REDIS_URL=redis://:<this>@redis:6379 inside compose.
REDIS_PASSWORD=change-me-strong-redis-password

# ---- Web (host port the browser hits; nginx listens on 80 in-container) ----
WEB_PORT=80

# Origin the browser uses to reach the app. With the nginx reverse proxy the
# UI is same-origin so CORS is not exercised, but set it to your real URL.
CORS_ORIGIN=http://localhost

# Absolute base for static file URLs (generated documents/assets/uploads).
# Leave empty for same-origin access; set to this box's address so download
# links handed out for external use are reachable, e.g. http://192.168.1.50:3000
PUBLIC_BASE_URL=

# ---- LLM (text) — at least one provider key is needed to run chat ----
# OpenAI-compatible (default points at DeepSeek; OpenAI / vLLM / etc. also work)
LLM_DEFAULT=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: log raw LLM request/response payloads for debugging (set to 1)
DEBUG_LLM=
