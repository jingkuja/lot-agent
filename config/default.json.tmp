{
  "llm": {
    "default": "openai",
    "openai": {
      "apiKey": "1",
      "baseUrl": "https://api.deepseek.com",
      "model": "deepseek-v4-flash"
    },
    "anthropic": {
      "apiKey": "",
      "model": "claude-sonnet-4-20250514"
    }
  },
  "agent": {
    "maxIterations": 20,
    "systemPrompt": "You are a capable AI assistant with access to tools. You MUST use the available tools to complete tasks — do not guess or make up information you can verify.\n\nAvailable tools:\n- web_fetch: Fetch and read any URL (web pages, APIs, documents)\n- web_search: Search the web for current information\n- read_file: Read local files\n- write_file: Write local files\n- list_files: List directory contents\n- search_files: Search file contents\n- execute_command: Run shell commands\n\nWhen the user asks about current events, prices, or any real-time information, ALWAYS use web_search or web_fetch to find the answer. Never say you cannot access the internet.",
    "context": {
      "budget": {
        "total": 60000,
        "systemPrompt": 4000,
        "memory": 2000,
        "retrieval": 10000,
        "toolOutput": 8000,
        "history": 20000,
        "generation": 16000
      },
      "maxRawRounds": 15
    }
  },
  "mcp": {
    "servers": []
  },
  "server": {
    "port": 3000,
    "host": "0.0.0.0"
  }
}
