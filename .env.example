# ─────────────────────────────────────────────────────────────
# Lot Agent — environment variables
# Copy to `.env` and fill in. Secrets live here; non-secret
# structure lives in config/default.json (override locally via
# config/local.json). Server throws on startup if PG_PASSWORD is missing.
# ─────────────────────────────────────────────────────────────

# LLM (text) — OpenAI-compatible. Default points at DeepSeek; any
# OpenAI-compatible endpoint works (OpenAI, DeepSeek, local vLLM, …).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# LLM (text) — Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Which text provider the agent uses by default: openai | anthropic
LLM_DEFAULT=openai

# PostgreSQL (business data). Server throws if PG_PASSWORD is empty.
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=lot

# Redis — BullMQ queue, generation cache, progress pub/sub
# Example dev value:
REDIS_URL=redis://:rag123456@localhost:6379
REDIS_PASSWORD=rag123456
# HTTP server
PORT=3000
# Allowed CORS origin for the web client (Vite dev server)
CORS_ORIGIN=http://localhost:5173
# Optional: absolute base for static file URLs (assets/documents/uploads).
# Leave empty for same-origin web access; set to the box's address so generated
# download links are reachable externally, e.g. http://192.168.1.50:3000
PUBLIC_BASE_URL=

# Optional: log raw LLM request/response payloads for debugging
DEBUG_LLM=
