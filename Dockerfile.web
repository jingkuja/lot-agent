# ─────────────────────────────────────────────────────────────
# Lot Agent — Web image. Builds the React/Vite static bundle, then serves it
# with nginx, which also reverse-proxies /api and /static to the server.
# ─────────────────────────────────────────────────────────────

# ---------- Stage 1: build web/dist ----------
FROM node:20-bookworm-slim AS builder
WORKDIR /app

# Workspace lockfile install needs every workspace manifest present.
COPY package.json package-lock.json ./
COPY packages/core/package.json packages/core/package.json
COPY packages/server/package.json packages/server/package.json
COPY packages/web/package.json packages/web/package.json
RUN npm ci

COPY tsconfig.base.json ./
COPY packages/web packages/web
RUN npm run build -w @lot-agent/web

# ---------- Stage 2: nginx static host + reverse proxy ----------
FROM nginx:1.27-alpine AS runtime
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/packages/web/dist /usr/share/nginx/html
EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://127.0.0.1/healthz >/dev/null 2>&1 || exit 1
